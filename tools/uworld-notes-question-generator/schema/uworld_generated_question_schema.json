{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "uworld-generated-question-v1",
  "title": "UWorld Generated Question (App-Ready v3)",
  "description": "App-ready question generated from UWorld notes using Gemini. Matches the canonical shamsulalamx nbme-gemini-json-v3 schema.",
  "type": "object",
  "required": [
    "schemaVersion",
    "testTitle",
    "sourceFormat",
    "expectedQuestionCount",
    "actualExtractedQuestionCount",
    "extractionWarnings",
    "questions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "nbme-gemini-json-v3"
    },
    "testTitle": {
      "type": "string"
    },
    "sourceFormat": {
      "type": "string",
      "const": "uworld-notes"
    },
    "expectedQuestionCount": {
      "type": ["integer", "null"]
    },
    "actualExtractedQuestionCount": {
      "type": ["integer", "null"]
    },
    "extractionWarnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "questionNumber",
          "sourceQuestionNumber",
          "retrievalTag",
          "reviewPearl",
          "clinicalPearl",
          "stem",
          "hasEmbeddedFigure",
          "figureRefs",
          "answerChoices",
          "correctAnswer",
          "educationalObjective",
          "explanationSections",
          "tables",
          "sharedGroup",
          "extractionWarnings"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^q[0-9]{3,}$"
          },
          "questionNumber": {
            "type": "integer",
            "minimum": 1
          },
          "sourceQuestionNumber": {
            "type": "integer",
            "minimum": 1
          },
          "retrievalTag": {
            "type": "string",
            "description": "Hyperspecific tag under 12 words. Not vague topic labels."
          },
          "reviewPearl": {
            "type": "string",
            "description": "One high-yield sentence."
          },
          "clinicalPearl": {
            "type": ["string", "null"]
          },
          "stem": {
            "type": "string",
            "minLength": 1
          },
          "hasEmbeddedFigure": {
            "type": "boolean"
          },
          "figureRefs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "answerChoices": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["label", "text"],
              "properties": {
                "label": {
                  "type": "string",
                  "pattern": "^[A-D]$"
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "correctAnswer": {
            "type": "string",
            "pattern": "^[A-D]$"
          },
          "educationalObjective": {
            "type": "string"
          },
          "explanationSections": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["heading", "body"],
              "properties": {
                "heading": {
                  "type": "string",
                  "enum": [
                    "Correct Answer Explanation",
                    "Incorrect Answer Explanation",
                    "Educational Objective"
                  ]
                },
                "body": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          },
          "tables": {
            "type": "array"
          },
          "sharedGroup": {
            "type": ["string", "null"]
          },
          "extractionWarnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
