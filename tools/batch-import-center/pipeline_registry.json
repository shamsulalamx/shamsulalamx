{
  "registryVersion": "batch-import-pipeline-registry-v1",
  "sources": {
    "emma_holiday_pdf": {
      "label": "Emma Holiday PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Emma Holiday shared-ingestion dry-run",
          "heartbeatSeconds": 30,
          "args": ["tools/shared-ingestion/emma_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "liveSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Emma Holiday shared-ingestion live generation",
          "heartbeatSeconds": 30,
          "args": ["tools/shared-ingestion/emma_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["tools/lecture-slide-question-generator/output_json/app_ready"],
      "notes": "Profile-style source: emits shared normalized chunks first, then invokes the existing Emma generator unchanged."
    },
    "mehlman_pdf": {
      "label": "Mehlman PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Mehlman shared-ingestion dry-run",
          "heartbeatSeconds": 20,
          "args": ["tools/shared-ingestion/mehlman_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "10"]
        }
      ],
      "liveSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Mehlman shared-ingestion live generation",
          "heartbeatSeconds": 20,
          "args": ["tools/shared-ingestion/mehlman_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "10"]
        }
      ],
      "outputDirectories": ["tools/mehlman-pdf-question-generator/output_json/app_ready"],
      "notes": "Profile-style text-heavy PDF source: emits shared normalized text chunks, then invokes the existing Mehlman generator unchanged. Initial validation is capped to the first 10 pages."
    },
    "images_tables_source": {
      "label": "Images & Tables",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".png", ".jpg", ".jpeg", ".webp", ".bmp", ".tif", ".tiff"],
      "allowDirectories": true,
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Images & Tables shared-ingestion dry-run (attachment-first stub, no Gemini)",
          "heartbeatSeconds": 10,
          "args": ["tools/shared-ingestion/images_tables_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "5"]
        }
      ],
      "liveSteps": [
        {
          "stage": "generation",
          "stageLabel": "Images & Tables live Gemini generation (per-image NBME-style questions)",
          "heartbeatSeconds": 30,
          "args": ["tools/shared-ingestion/images_tables_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["tools/images-tables-question-generator/output_json/app_ready"],
      "notes": "Live mode runs per-image Gemini classification + NBME-style question generation via tools/images-tables-question-generator/generate_images_tables_questions.py. Each Gemini call classifies the screenshot as diagnostic_stem_image, explanation_only_image, explanation_only_table, or unclear_skip. Diagnostic images that require interpretation go in q.images[] (stem); explanation-only images and ALL tables/charts go in q.explanationImages[] (explanation). Dry-run emits the prior attachment-first stub (no Gemini). Requires GEMINI_API_KEY. Selecting multiple files queues one generator call per file; selecting a folder scans it for supported image extensions."
    },
    "anki_notes": {
      "label": "Anki Notes",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".txt"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Anki shared-ingestion dry-run",
          "heartbeatSeconds": 10,
          "args": ["tools/shared-ingestion/anki_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "liveSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Anki shared-ingestion live generation",
          "heartbeatSeconds": 60,
          "args": ["tools/shared-ingestion/anki_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["tools/shared-ingestion/output/anki_app_ready_live", "tools/shared-ingestion/output/anki_app_ready_dry_run"],
      "notes": "Live Gemini Anki generation enabled. Dry-run produces placeholder questions; live runs Gemini to generate real questions (defaults to 15 per file via generate_anki_questions.py --questions-per-file). Requires GEMINI_API_KEY."
    },
    "ome_pdf": {
      "label": "OME PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "OME shared-ingestion dry-run",
          "heartbeatSeconds": 10,
          "args": ["tools/shared-ingestion/ome_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "liveSteps": [
        {
          "stage": "normalization",
          "stageLabel": "OME shared-ingestion live generation",
          "heartbeatSeconds": 60,
          "args": ["tools/shared-ingestion/ome_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["tools/shared-ingestion/output/ome_app_ready_live", "tools/shared-ingestion/output/ome_app_ready_dry_run"],
      "notes": "Live Gemini OME generation enabled. Dry-run produces placeholder questions; live runs Gemini to generate real clinical questions from the full PDF. Requires GEMINI_API_KEY."
    },
    "divine_transcript": {
      "label": "Divine (Audio + Transcript)",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".txt", ".md", ".mp3", ".m4a", ".wav"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Divine shared-ingestion dry-run (text inputs only)",
          "heartbeatSeconds": 10,
          "args": ["tools/shared-ingestion/divine_transcript_profile_runner.py", "--input-file", "{inputFile}", "--emit-app-ready-dry-run"]
        }
      ],
      "liveSteps": [
        {
          "stage": "generation",
          "stageLabel": "Divine live generation (audio → transcribe → clean → questions)",
          "heartbeatSeconds": 30,
          "args": ["tools/shared-ingestion/divine_transcript_profile_runner.py", "--input-file", "{inputFile}", "--emit-app-ready-live"]
        }
      ],
      "outputDirectories": [
        "tools/shared-ingestion/output/divine_app_ready_live",
        "tools/shared-ingestion/output/divine_app_ready_dry_run"
      ],
      "notes": "Accepts Divine Intervention podcast audio (.mp3/.m4a/.wav) and transcripts (.txt/.md). Dry-run handles text inputs only (audio dry-run is rejected to avoid wasting transcription tokens). Live mode runs the full pipeline: Gemini File API upload → transcribe → clean → chunk → generate (sourceFormat=divine-audio, schemaVersion=nbme-gemini-json-v3). Requires GEMINI_API_KEY."
    },
    "fast_facts_pptx": {
      "label": "Fast Facts PPTX",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pptx"],
      "workingDirectory": "tools/lecture-slide-question-generator",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "generation",
          "stageLabel": "Fast Facts dry-run",
          "heartbeatSeconds": 20,
          "args": ["generate_lecture_slide_questions.py", "--fast-facts-profile", "--input-file", "{inputFile}", "--limit", "10"]
        }
      ],
      "liveSteps": [
        {
          "stage": "generation",
          "stageLabel": "Fast Facts live generation",
          "heartbeatSeconds": 20,
          "args": ["generate_lecture_slide_questions.py", "--fast-facts-profile", "--generate", "--fast-facts-diagnostic-report", "--no-reuse-cache", "--input-file", "{inputFile}"]
        }
      ],
      "outputDirectories": ["output_json/app_ready"],
      "notes": "Uses the existing FAST_FACTS_PROFILE in the lecture-slide generator. Live generation does not apply a question or slide cap unless explicitly requested."
    },
    "amboss_pdf": {
      "label": "AMBOSS PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": "tools/lecture-slide-question-generator",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "extraction",
          "stageLabel": "AMBOSS dry-run (first 5 pages, sanity check)",
          "heartbeatSeconds": 20,
          "args": ["generate_lecture_slide_questions.py", "--amboss-profile", "--input-file", "{inputFile}", "--limit", "5"]
        }
      ],
      "liveSteps": [
        {
          "stage": "extraction",
          "stageLabel": "AMBOSS live extraction (all pages)",
          "heartbeatSeconds": 20,
          "args": ["generate_lecture_slide_questions.py", "--amboss-profile", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["output_json/app_ready"],
      "notes": "AMBOSS QBank PDF (browser screenshot export). Tesseract OCR groups pages into questions and routes click-to-enlarge image pages to explanations; one Gemini call per question extracts clean choices, correct answer, explanations, and review pearl. ~8 calls / ~$0.10 per typical PDF."
    },
    "nbme_pdf": {
      "label": "NBME PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": "tools/nbme-pdf-json-generator",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "OCR",
          "stageLabel": "NBME dry-run OCR",
          "heartbeatSeconds": 15,
          "args": ["nbme_batch_wrapper.py", "--stage", "ocr", "--input-file", "{inputFile}", "--max-pages", "5"]
        },
        {
          "stage": "chunking",
          "stageLabel": "NBME dry-run chunking",
          "heartbeatSeconds": 15,
          "args": ["nbme_batch_wrapper.py", "--stage", "chunking", "--input-file", "{inputFile}", "--max-pages", "5"]
        },
        {
          "stage": "normalization",
          "stageLabel": "NBME dry-run normalization",
          "heartbeatSeconds": 20,
          "args": ["nbme_batch_wrapper.py", "--stage", "normalization", "--dry-run", "--input-file", "{inputFile}", "--max-pages", "5"]
        }
      ],
      "liveSteps": [
        {
          "stage": "OCR",
          "stageLabel": "OCR",
          "heartbeatSeconds": 15,
          "args": ["nbme_batch_wrapper.py", "--stage", "ocr", "--input-file", "{inputFile}", "--max-pages", "5"]
        },
        {
          "stage": "chunking",
          "stageLabel": "chunking",
          "heartbeatSeconds": 15,
          "args": ["nbme_batch_wrapper.py", "--stage", "chunking", "--input-file", "{inputFile}", "--max-pages", "5"]
        },
        {
          "stage": "normalization",
          "stageLabel": "normalization",
          "heartbeatSeconds": 20,
          "args": ["nbme_batch_wrapper.py", "--stage", "normalization", "--input-file", "{inputFile}", "--max-pages", "5"]
        },
        {
          "stage": "app-ready conversion",
          "stageLabel": "app-ready conversion",
          "heartbeatSeconds": 15,
          "args": ["nbme_batch_wrapper.py", "--stage", "app-ready", "--input-file", "{inputFile}", "--max-pages", "5"]
        }
      ],
      "outputDirectories": ["output_json/app_ready"],
      "notes": "Uses a thin Batch Import wrapper around the existing NBME PDF generator stages. Initial validation is capped to the first 5 pages."
    }
  },
  "placeholders": {
    "uworld_notes": {
      "status": "placeholder",
      "notes": "Existing external notes pipeline exists, but it is not part of the initial Batch Import Center registry."
    }
  }
}
