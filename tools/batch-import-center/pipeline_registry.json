    "emma_holiday_pdf": {
      "label": "Emma Holiday PDF",
      "status": "active",
      "requiresGemini": true,
      "inputExtensions": [".pdf"],
      "workingDirectory": ".",
      "pythonExecutable": "python3",
      "dryRunSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Emma Holiday shared-ingestion dry-run",
          "heartbeatSeconds": 20,
          "args": ["tools/shared-ingestion/emma_profile_runner.py", "--mode", "dry-run", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "liveSteps": [
        {
          "stage": "normalization",
          "stageLabel": "Emma Holiday shared-ingestion live generation",
          "heartbeatSeconds": 20,
          "args": ["tools/shared-ingestion/emma_profile_runner.py", "--mode", "generate", "--input-file", "{inputFile}", "--limit", "0"]
        }
      ],
      "outputDirectories": ["tools/lecture-slide-question-generator/output_json/app_ready"],
      "notes": "Profile-style source: emits shared normalized chunks first, then invokes the existing Emma generator unchanged."
    },
